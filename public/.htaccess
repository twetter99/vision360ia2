# =============================================================================
# Vision360IA - .htaccess para SiteGround
# =============================================================================
# Este fichero acompaña al build estático (out/) y aplica:
#   - Redirección HTTPS + www canonical
#   - Cabeceras de seguridad (HSTS, CSP, X-Frame-Options, etc.)
#   - Compresión gzip / brotli
#   - Cache largo para assets estáticos
#   - Rutas amigables sin extensión .html
#
# El endpoint PHP del formulario tiene su propio .htaccess en /api/form/.
# =============================================================================

# ---------------------------------------------------------------------
# 1) HTTPS + dominio canónico
# ---------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forzar HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Forzar www (vision360ia.com -> www.vision360ia.com)
    RewriteCond %{HTTP_HOST} ^vision360ia\.com$ [NC]
    RewriteRule ^(.*)$ https://www.vision360ia.com/$1 [R=301,L]

    # Servir HTML sin extensión: /quienes-somos -> /quienes-somos.html
    # (Next.js export con trailingSlash:false produce ficheros .html en la raíz
    #  de out/ para rutas top-level.)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.+?)/?$ /$1.html [L]
</IfModule>

# ---------------------------------------------------------------------
# 2) Cabeceras de seguridad
# ---------------------------------------------------------------------
<IfModule mod_headers.c>
    # HSTS - 2 años, incluyendo subdominios.
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # Anti-MIME-sniffing y anti-clickjacking
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer y permisos de APIs sensibles del navegador
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-DNS-Prefetch-Control "on"

    # Content-Security-Policy (mismas fuentes que el next.config original).
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://challenges.cloudflare.com https://static.cloudflareinsights.com https://www.google.com https://www.gstatic.com https://www.googletagmanager.com https://player.vimeo.com blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://challenges.cloudflare.com https://static.cloudflareinsights.com https://www.google-analytics.com https://www.googletagmanager.com https://region1.google-analytics.com https://www.google.com https://www.googleadservices.com; frame-src https://challenges.cloudflare.com https://www.google.com https://player.vimeo.com https://www.googletagmanager.com; worker-src 'self' blob:; child-src 'self' blob: https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self';"

    # Ocultar X-Powered-By y Server cuando se pueda
    Header unset X-Powered-By
</IfModule>

# ---------------------------------------------------------------------
# 3) Charset por defecto UTF-8 (importante para .txt como llms.txt)
#    Sin esto Safari interpreta .txt como ISO-8859-1 y los acentos
#    aparecen como "más" → "mÃ¡s".
#    En SiteGround (nginx delante de Apache) hay que forzar el header
#    explícitamente porque AddDefaultCharset no se propaga.
# ---------------------------------------------------------------------
AddDefaultCharset UTF-8
AddCharset UTF-8 .txt .html .css .js .json .xml .svg

<IfModule mod_headers.c>
    <FilesMatch "\.txt$">
        Header set Content-Type "text/plain; charset=utf-8"
    </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------
# 4) Compresión
# ---------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf application/font-woff application/font-woff2
</IfModule>

# ---------------------------------------------------------------------
# 4) Cache de assets estáticos
# ---------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML siempre fresco (revalidación)
    ExpiresByType text/html "access plus 0 seconds"

    # Assets con hash en el nombre: cache largo
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Para los chunks de Next.js (carpeta _next/static) el filename incluye hash,
    # así que es seguro un cache inmutable.
    <FilesMatch "\.(css|js|woff2|woff|ttf|otf|jpg|jpeg|png|webp|avif|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------
# 5) Páginas de error
# ---------------------------------------------------------------------
ErrorDocument 404 /404.html

# ---------------------------------------------------------------------
# 6) Bloquear ficheros sensibles
# ---------------------------------------------------------------------
<FilesMatch "^(\.env.*|.*\.bak|.*\.old|.*\.swp|composer\.json|composer\.lock|package\.json|package-lock\.json|tsconfig\.json)$">
    Require all denied
</FilesMatch>
