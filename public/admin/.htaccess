# CSP específica para /admin (Sveltia CMS). Solo afecta a esta carpeta:
# si algo falla aquí, NO afecta al resto del sitio.
# Relajamos respecto a la global para permitir que el CMS hable con GitHub y
# con el proxy OAuth. El bundle de Sveltia está auto-alojado (script 'self').

<IfModule mod_headers.c>
  Header always unset Content-Security-Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.github.com https://*.githubusercontent.com https://github.com https://unpkg.com https://vision360-cms-auth.twetter.workers.dev; frame-src 'self' https://vision360-cms-auth.twetter.workers.dev; worker-src 'self' blob:; child-src 'self' blob:; form-action 'self' https://github.com https://vision360-cms-auth.twetter.workers.dev; base-uri 'self';"

  # El login abre una ventana emergente; quitamos el DENY heredado por si acaso.
  Header always unset X-Frame-Options

  # Referer permisivo SOLO en /admin: el proxy OAuth valida por Referer, y la
  # política global (strict-origin-when-cross-origin) puede no enviarlo en el
  # popup. unsafe-url garantiza que se envíe el origen. (No afecta al resto.)
  Header always unset Referrer-Policy
  Header always set Referrer-Policy "unsafe-url"
</IfModule>

# No indexar el panel
<IfModule mod_headers.c>
  Header always set X-Robots-Tag "noindex, nofollow"
</IfModule>
